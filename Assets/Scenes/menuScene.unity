  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Tento projekt byl vypracov\xE1n v r\xE1mci p\u0159edm\u011Btu IKT ve 4.
    ro\u010Dn\xEDku SP\u0160E.\n\nJeho c\xEDlem bylo sezn\xE1mit se s prost\u0159ed\xEDm
    unity a vytvo\u0159it VR hru. Co n\xE1s inspirovalo? Jedna hra, kde se mus\xED
    proch\xE1zet minov\xE9 pole a na miny se \u0161lape oproti klasick\xE9 2D verzi.
    Tato hra je THE MINEFIELDS od autor\u016F ByteSized Studios.\n\nPro\u010D Mines
    for des2ert? Desert jako pou\u0161\u0165, z\xE1rov\u011B\u0148 tak\xE9 jako z\xE1kusek\r\n\n\t\t\t   
    Frapp\xE9 Industries v roce 2026.\n\n\tPod\u011Bkov\xE1n\xED pat\u0159\xED na\u0161im
    u\u010Ditel\u016Fm a francouzsk\xFDm tutori\xE1l\u016Fm."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5b036e831c0c90547b32a8a896d80f79, type: 2}
  m_sharedMaterial: {fileID: 6988543560108305873, guid: cb4516ac98eb5854ea4d7a8f558eb4da, type: 2}
